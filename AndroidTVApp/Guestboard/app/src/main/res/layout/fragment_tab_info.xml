<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:layout_width="680dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:maxHeight="500dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_frosted_card"
            android:padding="40dp">

            <!-- Host Contact -->
            <TextView
                android:id="@+id/section_contact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/host_label"
                android:textColor="@color/accent"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />
            <TextView
                android:id="@+id/host_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/host_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:layout_marginTop="4dp" />
            <TextView
                android:id="@+id/host_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:layout_marginTop="4dp" />

            <!-- Divider -->
            <View
                android:id="@+id/divider1"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="20dp" />

            <!-- WiFi -->
            <LinearLayout
                android:id="@+id/wifi_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <!-- Text on the left -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wifi_network_label"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/wifi_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wifi_password_label"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp"
                        android:layout_marginTop="10dp" />
                    <TextView
                        android:id="@+id/wifi_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- QR code on the right -->
                <ImageView
                    android:id="@+id/wifi_qr"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginStart="16dp"
                    android:background="#ffffff"
                    android:padding="4dp"
                    android:visibility="gone" />
            </LinearLayout>

            <View
                android:id="@+id/wifi_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="20dp"
                android:visibility="gone" />

            <!-- Check-in / Check-out -->
            <LinearLayout
                android:id="@+id/dates_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Check-in"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/checkin_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:layout_marginTop="2dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Checkout"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp" />
                <TextView
                    android:id="@+id/checkout_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
